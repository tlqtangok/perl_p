
# >>> conda initialize >>>
# !! Contents within this block are managed by 'conda init' !!
__conda_setup="$('/home/heer/anaconda3/bin/conda' 'shell.bash' 'hook' 2> /dev/null)"
if [ $? -eq 0 ]; then
    eval "$__conda_setup"
else
    if [ -f "/home/heer/anaconda3/etc/profile.d/conda.sh" ]; then
        . "/home/heer/anaconda3/etc/profile.d/conda.sh"
    else
        export PATH="/home/heer/anaconda3/bin:$PATH"
    fi
fi
unset __conda_setup
# <<< conda initialize <<<



### jd add ###
export t=/home/heer/jd/t
export t0=$t/t0
export perl_p=$t/perl_p

#SSH_FROM=$(echo $SSH_CLIENT | awk '{print SSH_CLIENT is $1}')
#echo SSH_FROM: $SSH_FROM

#[ -f $perl_p/.bashrc ] && source $perl_p/.bashrc

if [ -n "$SSH_CLIENT" ]; then
     SSH_FROM=$(echo $SSH_CLIENT | awk '{print $1}')
    if [[ "$SSH_FROM" == 192.168.2.129 ]]; then
        [ -f $perl_p/.bashrc ] && source $perl_p/.bashrc
    fi
fi

